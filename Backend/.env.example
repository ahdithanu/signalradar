# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://signal_user:signal_pass@localhost:5432/signal_radar

# ── App ───────────────────────────────────────────────────────────────
# Set to "production" for live deploy (enables safety checks, disables seeding)
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Must include your frontend URL in production.
# Example prod: https://signalradar.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Supabase Auth ─────────────────────────────────────────────────────
# Required in production (AUTH_ENABLED=true).
# Get values from: Supabase Dashboard → Settings → API
AUTH_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── Optional ──────────────────────────────────────────────────────────
CRUNCHBASE_API_KEY=
